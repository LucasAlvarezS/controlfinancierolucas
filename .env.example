# --- Base de datos (Supabase u otro Postgres) ---
# Runtime de la app. En producción con Supabase usar la conexión POOLED (puerto 6543).
DATABASE_URL="postgresql://postgres:password@localhost:5432/control_financiero"
# Migraciones y seed (prisma.config.ts). Con Supabase usar la conexión DIRECTA (puerto 5432).
DIRECT_URL="postgresql://postgres:password@localhost:5432/control_financiero"

# --- Auth.js (login con Google) ---
# Generar con: npx auth secret
AUTH_SECRET=""
# OAuth Client ID de Google Cloud Console (tipo "Web application",
# redirect URI: <APP_URL>/api/auth/callback/google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Emails de Google autorizados, separados por coma. Si queda vacío, nadie puede entrar.
ALLOWED_EMAILS="tu-email@gmail.com"

# --- Cifrado de tokens de integraciones ---
# Generar con: openssl rand -base64 32
ENCRYPTION_KEY=""

# --- Cron de sincronización ---
# Debe coincidir con el secret CRON_SECRET configurado en GitHub Actions.
CRON_SECRET=""

# --- Widget del iPhone (Scriptable) ---
# Protege /api/widget/summary. Generar con: openssl rand -base64 32
# El mismo valor va en el script de Scriptable (scripts/iphone-widget.js).
WIDGET_SECRET=""

# --- Mercado Pago (opcional en local; necesario para la fase 2) ---
MERCADOPAGO_CLIENT_ID=""
MERCADOPAGO_CLIENT_SECRET=""
# <APP_URL>/api/integrations/mercadopago/callback
MERCADOPAGO_REDIRECT_URI=""
# "Firma secreta" del panel de webhooks de Mercado Pago.
# Si queda vacío, los webhooks entrantes se rechazan con 401.
MERCADOPAGO_WEBHOOK_SECRET=""

# --- Fintoc (opcional en local; necesario para la fase 3) ---
FINTOC_SECRET_KEY=""
FINTOC_PUBLIC_KEY=""
# Secreto del endpoint de webhooks de Fintoc (whsec_...).
# Si queda vacío, los webhooks entrantes se rechazan con 401.
FINTOC_WEBHOOK_SECRET=""
